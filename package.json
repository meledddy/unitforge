{
  "name": "unitforge",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "db:generate": "pnpm --filter @unitforge/db db:generate",
    "db:migrate": "pnpm --filter @unitforge/db db:migrate",
    "db:seed:mock-session": "tsx --tsconfig tsconfig.base.json packages/db/src/scripts/seed-mock-session.ts",
    "onboard:pilot": "tsx --tsconfig tsconfig.base.json packages/db/src/scripts/onboard-pilot-user.ts",
    "dev": "pnpm --filter @unitforge/web dev",
    "build": "pnpm --filter \"./packages/**\" build && pnpm --filter @unitforge/web build",
    "lint": "pnpm --filter \"./packages/**\" lint && pnpm --filter @unitforge/web lint",
    "typecheck": "pnpm --filter \"./packages/**\" typecheck && pnpm --filter @unitforge/web typecheck",
    "verify:auth": "tsx --tsconfig tsconfig.base.json apps/web/scripts/verify-auth.ts",
    "verify:onboarding": "tsx --tsconfig tsconfig.base.json apps/web/scripts/verify-pilot-onboarding.ts",
    "verify:price-sheets": "tsx --tsconfig tsconfig.base.json apps/web/scripts/verify-price-sheets.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.20.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
